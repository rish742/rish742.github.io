rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email == "replace-me@example.com";
    }

    match /blog-covers/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
